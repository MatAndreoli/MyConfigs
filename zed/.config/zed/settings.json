// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ── Appearance ────────────────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro Vivid",
  },
  "theme_overrides": {
    "One Dark": {
      "border.variant": "#262b32ff",
      "border": "#2f323bff",
      "title_bar.background": "#202329ff",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
    "One Dark Pro Vivid": {
      "border.variant": "#23272eff",
      "border": "#202329ff",
      "title_bar.background": "#1e2227ff",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme",
  },
  "ui_font_size": 16,
  "buffer_font_family": ".ZedMono",
  "buffer_font_size": 15,
  "cursor_blink": false,
  "active_pane_modifiers": {
    "inactive_opacity": 0.75,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "file_finder": {
    "modal_max_width": "medium",
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 5,
  "soft_wrap": "none",
  "preferred_line_length": 80,
  "wrap_guides": [120],
  "show_whitespaces": "selection",
  "inlay_hints": { "enabled": true },
  "lsp_document_colors": "inlay",
  "auto_signature_help": false,
  "show_signature_help_after_edits": true,
  "inline_code_actions": false,
  "extend_comment_on_newline": false,
  "seed_search_query_from_cursor": "selection",
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": true,
  },

  // ── Formatting ────────────────────────────────────────────────────────────
  "formatter": "auto",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,

  // ── Files ─────────────────────────────────────────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/reports/mutation",
  ],
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": true,
    "enable_preview_from_file_finder": true,
    "enable_preview_from_multibuffer": true,
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_file_from_code_navigation": true,
    "enable_keep_preview_on_code_navigation": true,
  },

  // ── Panels & Docks ────────────────────────────────────────────────────────
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "project_panel": {
    "dock": "left",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },

  // ── Terminal ──────────────────────────────────────────────────────────────
  "terminal": {
    "font_family": ".ZedMono",
    "shell": {
      "program": "zsh",
    },
  },

  // ── Git ───────────────────────────────────────────────────────────────────
  "git": {
    "inline_blame": { "enabled": true, "show_commit_summary": true },
  },

  // ── Language overrides ────────────────────────────────────────────────────
  "languages": {
    "Java": {
      "formatter": "language_server",
      "wrap_guides": [120],
    },
    "Python": {
      "wrap_guides": [88],
    },
  },

  // ── Java ──────────────────────────────────────────────────────────────────
  "lsp": {
    "jdtls": {
      "settings": {
        "java_home": "~/.sdkman/candidates/java/21.0.8-oracle",
        "lombok_support": true,
        "check_updates": "never",
      },
      "initialization_options": {
        "settings": {
          "java": {
            "configuration": {
              "updateBuildConfiguration": "automatic",
              "runtimes": [
                {
                  "name": "JavaSE-17",
                  "path": "~/.sdkman/candidates/java/17.0.12-oracle",
                },
                {
                  "name": "JavaSE-21",
                  "path": "~/.sdkman/candidates/java/21.0.8-oracle",
                  "default": true,
                },
              ],
              "maven": {
                "userSettings": "~/.m2/settings.xml",
              },
            },
            "saveActions": {
              "organizeImports": true,
            },
            "eclipse": { "downloadSources": true },
            "maven": { "downloadSources": true },
            "autobuild": { "enabled": true },
            "import": {
              "maven": {
                "enabled": true,
                "home": "~/.sdkman/candidates/maven/3.8.6",
              },
            },
            "inlayHints": {
              "parameterNames": { "enabled": "all" },
            },
            "signatureHelp": {
              "enabled": true,
              "description": { "enabled": true },
            },
            "format": {
              "enabled": true,
              "settings": {
                "url": "~/.config/zed/intellij-style.xml",
              },
              "onType": { "enabled": false },
            },
            "completion": {
              "enabled": true,
              "favoriteStaticMembers": [
                "org.junit.jupiter.api.Assertions.*",
                "org.junit.jupiter.api.Assumptions.*",
                "org.mockito.Mockito.*",
                "org.mockito.ArgumentMatchers.*",
              ],
              "importOrder": ["java", "javax", "com", "org"],
              "postfix": { "enabled": true },
              "guessMethodArguments": "insertParameterNames",
            },
            "references": {
              "includeDecompiledSources": true,
            },
            "referencesCodeLens": { "enabled": true },
          },
        },
      },
    },
  },

  // ── Session & Privacy ─────────────────────────────────────────────────────
  "cli_default_open_behavior": "new_window",
  "session": {
    "trust_all_worktrees": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
}
